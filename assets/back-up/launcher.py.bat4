        tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        tv.get_style_context().add_class("console")
        log_buf = tv.get_buffer()
        log_buf.set_text(read_gamelog())
        sw.add(tv)
        outer.pack_start(sw, True, True, 0)
        return outer

