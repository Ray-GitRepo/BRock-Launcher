        """Game startup log viewer — replaces old GameLog nav item."""
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        outer.set_margin_start(26); outer.set_margin_end(26); outer.set_margin_top(14); outer.set_margin_bottom(26)

